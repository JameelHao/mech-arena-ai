    "@vercel/node": "^5.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "engines": {
    "node": ">=22"
  }
